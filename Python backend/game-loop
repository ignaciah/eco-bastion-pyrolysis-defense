import uuid
import math
from typing import Dict, List, Any

class WasteEntity:
    def __init__(self, waste_type: str, volume: float, integrity: float):
        self.id = uuid.uuid4()
        self.waste_type = waste_type  # 'plastic', 'tire', 'chemical'
        self.volume = volume          # Total mass to process
        self.integrity = integrity    # "Health" equivalent

class ProcessingNode:
    def __init__(self, node_type: str, process_rate: float, efficiency: float):
        self.id = uuid.uuid4()
        self.node_type = node_type    # 'thermal_cracker', 'shredder', 'catalytic'
        self.process_rate = process_rate
        self.efficiency = efficiency
        self.accumulated_heat = 0.0

    def process(self, entity: WasteEntity) -> Dict[str, float]:
        """Calculates material degradation and resource yields via pyrolysis conversion equations."""
        if entity.integrity <= 0:
            return {"syngas": 0, "oil": 0, "carbon_black": 0}

        # Calculate processing throughput
        damage = min(self.process_rate, entity.integrity)
        entity.integrity -= damage
        processed_ratio = damage / entity.volume
        
        # Heat accumulation scaling law
        self.accumulated_heat += (damage * 0.12) / (1.0 + (self.efficiency * 0.5))

        # Yield tables based on processing profiles
        yields = {"syngas": 0.0, "oil": 0.0, "carbon_black": 0.0}
        if self.node_type == 'thermal_cracker':
            if entity.waste_type == 'plastic':
                yields["oil"] = damage * 0.60 * self.efficiency
                yields["syngas"] = damage * 0.25 * self.efficiency
            elif entity.waste_type == 'tire':
                yields["oil"] = damage * 0.40 * self.efficiency
                yields["carbon_black"] = damage * 0.35 * self.efficiency
                
        return yields

class SimulationEngine:
    def __init__(self):
        self.nodes: List[ProcessingNode] = []
        self.active_waves: List[WasteEntity] = []
        self.resources = {"syngas": 50.0, "oil": 100.0, "carbon_black": 10.0}
        self.grid_score = 100.0

    def add_node(self, node: ProcessingNode):
        self.nodes.append(node)

    def spawn_wave(self, waste_type: str, count: int, scale: float):
        for _ in range(count):
            self.active_waves.append(WasteEntity(waste_type, 10.0 * scale, 15.0 * scale))

    def step_simulation(self) -> Dict[str, Any]:
        """Executes a single structural tick of the engine loop."""
        total_yields = {"syngas": 0.0, "oil": 0.0, "carbon_black": 0.0}
        
        # Process active targets
        for node in self.nodes:
            if not self.active_waves:
                break
                
            # Node targets the lead item in the stream
            target = self.active_waves[0]
            node_yields = node.process(target)
            
            for k in total_yields:
                total_yields[k] += node_yields[k]
                
            if target.integrity <= 0:
                self.active_waves.pop(0)

        # Update global resource inventory
        for r_type, amount in total_yields.items():
            self.resources[r_type] += amount

        # Handle environmental leakage if items breach defenses
        for entity in self.active_waves:
            # Simulation penalty tracking for unprocessed items over time
            self.grid_score -= (entity.integrity * 0.01)
            
        return {
            "resources": self.resources,
            "active_threats": len(self.active_waves),
            "grid_score": max(0.0, self.grid_score)
        }

# Verify loop integrity execution
if __name__ == "__main__":
    engine = SimulationEngine()
    engine.add_node(ProcessingNode('thermal_cracker', process_rate=3.5, efficiency=0.85))
    
    print("Initializing Wave 1: Polyethylene Influx...")
    engine.spawn_wave('plastic', count=3, scale=1.2)
    
    for tick in range(1, 6):
        status = engine.step_simulation()
        print(f"Tick {tick} -> Remaining Targets: {status['active_threats']} | Score: {status['grid_score']:.2f} | Oil Bank: {status['resources']['oil']:.2f}")


