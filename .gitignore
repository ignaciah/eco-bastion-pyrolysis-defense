# This .gitignore file is automatically configured for Unity projects
#
# Covers Files and Folders generated by the Unity Editor

/[尝濒]ibrary/
/[罢迟]emp/
/[翱辞]bj/
/[叠产]uild/
/[叠产]uilds/
/[尝濒]ogs/
/[鲍耻]ser[厂蝉]ettings/

# Memory dumps and crash logs
*.spl
*.unitypackage
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svclog
*.saved

# Unity 3D generated meta files
# Only ignore meta files if they are inside an ignored folder
!/[础补]ssets/**/*.meta

# Crashlytics and target build outputs
/[础补]ndroid/
/[滨滨]OS/
/_Builds/

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
Icon?
ehthumbs.db

